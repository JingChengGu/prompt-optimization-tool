# Copy this file to .env and fill in your values.
# Load with: export $(cat .env | xargs)  — or use python-dotenv if preferred.

# Dify instance base URL (no trailing slash)
DIFY_BASE_URL=https://api.dify.ai/v1

# Workflow A — per-batch suggestion extraction (Gemini 2.5 Flash)
DIFY_WORKFLOW_A_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# Workflow B — dedup + clustering (Gemini 2.5 Flash)
DIFY_WORKFLOW_B_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# Workflow C — final prompt assembly (Claude Sonnet / GPT-5.5)
DIFY_WORKFLOW_C_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx
